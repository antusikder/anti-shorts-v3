<?xml version="1.0" encoding="utf-8"?>
<!--
  AntiShortsService Configuration
  ================================
  This file configures the Android Accessibility Service.

  Key decisions:
  - packageNames: ONLY YouTube and Facebook. We do NOT monitor any other apps.
    This is a privacy and performance requirement.
  - accessibilityEventTypes: We listen for window state changes AND content changes
    so we can detect both app opens and feed scrolling events.
  - accessibilityFlags: We retrieve view IDs and include non-important views so we
    can find the exact nodes we need (e.g. Shorts headers, ad labels).
  - canRetrieveWindowContent="true": Required to read the view hierarchy.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/accessibility_service_description"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:packageNames="com.google.android.youtube,com.facebook.katana"
    android:accessibilityFlags="flagDefault|flagIncludeNotImportantViews|flagRetrieveInteractiveWindows|flagReportViewIds"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="100"
    android:settingsActivity="com.antishorts.shield.MainActivity" />
